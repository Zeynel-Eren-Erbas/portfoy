{
  "entities": {
    "messages": {
      "title": "Messages",
      "description": "Contact form messages from the portfolio website",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender's name" },
        "email": { "type": "string", "format": "email", "description": "Sender's email" },
        "subject": { "type": "string", "description": "Message subject" },
        "message": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of message creation" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "projects": {
      "title": "Projects",
      "description": "Portfolio projects to display",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "githubUrl": { "type": "string", "format": "uri" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "order": { "type": "number" }
      },
      "required": ["title", "description", "order"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "messages",
      "description": "Collection of contact messages"
    },
    "/projects/{projectId}": {
      "schema": "projects",
      "description": "Collection of portfolio projects"
    }
  }
}
